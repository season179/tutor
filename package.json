{
  "name": "tutor",
  "version": "1.0.0",
  "packageManager": "pnpm@11.6.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "expo": "~56.0.11",
    "expo-camera": "~56.0.8",
    "expo-file-system": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "jose": "^6.2.3",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:worker",
    "typecheck:app": "tsc --noEmit",
    "typecheck:worker": "tsc -p workers/tutor-backend/tsconfig.json --noEmit",
    "worker:deploy": "wrangler deploy --config workers/tutor-backend/wrangler.jsonc",
    "worker:dev": "wrangler dev --config workers/tutor-backend/wrangler.jsonc",
    "worker:dry-run": "wrangler deploy --dry-run --config workers/tutor-backend/wrangler.jsonc",
    "worker:types": "wrangler types --config workers/tutor-backend/wrangler.jsonc workers/tutor-backend/worker-configuration.d.ts"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.2.17",
    "typescript": "~6.0.3",
    "wrangler": "^4.100.0"
  }
}
